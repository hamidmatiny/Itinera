# xAI (Grok) — required unless mock mode is enabled
XAI_API_KEY=Your_XAI_API_KEY_Here
XAI_MODEL=grok-4.3
XAI_BASE_URL=https://api.x.ai/v1

# Optional: use mock data without calling xAI
USE_MOCK_LLM=false

# Backend URL for Streamlit frontend
API_BASE_URL=http://127.0.0.1:8000

# Retry count when LLM JSON fails validation
LLM_MAX_RETRIES=3

# SQLite (local) — swap for postgresql+asyncpg://... in production
DATABASE_URL=sqlite+aiosqlite:///./itinera.db
DATABASE_ECHO=false

# Public Streamlit URL for share links (no trailing slash)
APP_PUBLIC_URL=http://localhost:8501

# Agentic Search-then-Synthesize (xAI Responses API + web_search)
ENABLE_WEB_SEARCH=true
